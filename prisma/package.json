{
  "name": "@shared/prisma",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./generated/prisma/client.ts",
      "default": "./dist/client.js"
    }
  },
  "prisma": {
    "schema": "schema.prisma"
  },
  "scripts": {
    "build": "esbuild generated/prisma/client.ts --bundle --platform=node --format=esm --outfile=dist/client.js --external:@prisma/client",
    "generate": "npx prisma generate && npm run build",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "studio": "npx prisma studio",
    "format": "npx prisma format"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.5.0"
  }
}
