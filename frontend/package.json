{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:app chakra:watch",
    "dev:app": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "lint": "biome check --apply-unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "preview": "vite preview",
    "generate-client": "openapi-ts",
    "chakra:types": "npx @chakra-ui/cli typegen ./src/theme/index.ts --outdir ./src/theme/types > NUL 2>&1",
    "chakra:watch": "chokidar \"src/theme/**/*.ts\" \"!src/theme/**/*.d.ts\" -c \"npm run chakra:types\" > NUL 2>&1",
    "test:watch": "chokidar \"src/theme/**/*.ts\" -c \"npm run test:watch\"",
    "test:watch-chok": "echo testing"
  },
  "dependencies": {
    "@chakra-ui/cli": "^3.21.0",
    "@chakra-ui/react": "^3.21.0",
    "@emotion/react": "^11.14.0",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-query-devtools": "^5.81.2",
    "@tanstack/react-router": "1.121.27",
    "axios": "1.10.0",
    "form-data": "4.0.3",
    "framer-motion": "^12.18.1",
    "konva": "^10.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "7.58.1",
    "react-icons": "^5.5.0",
    "react-konva": "^19.2.3",
    "react-use-websocket": "^4.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "@hey-api/openapi-ts": "^0.76.0",
    "@playwright/test": "^1.53.1",
    "@tanstack/router-devtools": "1.121.27",
    "@tanstack/router-plugin": "^1.121.29",
    "@tanstack/router-vite-plugin": "1.121.29",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "baseline-browser-mapping": "^2.10.16",
    "chokidar-cli": "^3.0.0",
    "dotenv": "^16.5.0",
    "jsdom": "^26.1.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
